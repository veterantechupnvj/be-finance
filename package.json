{
  "name": "finance-api",
  "version": "1.0.0",
  "description": "Backend for VeteranTech Finance Dashboard (Hono + Drizzle + Postgres)",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'bun' src/index.ts",
    "build": "tsc --noEmit",
    "start": "bun src/index.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "check-lint": "oxlint --check",
    "check-format": "oxfmt --check",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "seed:dev": "bun src/scripts/seed-dev.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.0.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
